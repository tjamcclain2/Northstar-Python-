"""
Whitening and bandpassing are two conditioning steps that turn raw noisy detector data into something where a chirp is
visible.

Whitening flattens the noise spectrum. Real detector noise is strongly "colored" the aLIGOZeroDetHighPower PSD in the
code has enormous power at low frequency. Low frequency noise would completely dominate everything in a raw strain and
whitening divides the data in the frequency domain by the noise amplitude spectral density. The effect is that each
frequency's contribution is now measured relative to how noisy the detector is there: quiet, sensitive bands get
emphasized, loud noisy bands get suppressed, and a signal that was buried under the colored floor emerges.

Bandpassing then restricts to the band that actually carries signal. In this code the highpass(30) removes residual
sub-30 Hz content (low-frequency junk and whitening artifacts near the f_low edge), and lowpass_fir(300, 8)
removes everything above 300 Hz.

The reason that this is effective because whitening converts a hard colored-noise problem into an easy white-noise one.
Bandpassing adds to this by discarding bands that contribute only noise, which improves the signal-to-noise ratio of
what remains and makes the chirp legible to both a matched filter and the eye.

For certain noise levels the whitening and bandpass eventually break down. For bandpassing it is important to note that
it is signal dependent so the wrong choice throws away real signal. 300 Hz lowpass is fine for a heavy black-hole
merger, but it would destroy a binary-neutron-star signal that sweeps up to a kilohertz.
"""
from pycbc.psd import from_string
from pycbc.noise import noise_from_psd
from pycbc.types import TimeSeries
from pycbc.filter import highpass, lowpass_fir
from pycbc.waveform import get_td_waveform          
import matplotlib
matplotlib.use("Agg")              # headless backend: render to PNG, no GUI window
import matplotlib.pyplot as plt
import warnings
warnings.filterwarnings("ignore")  # suppress PyCBC/matplotlib deprecation chatter

# --------------------------------------------------------------------------
# 0. Configuration
# --------------------------------------------------------------------------
# All tunable knobs collected here so the physics sections stay uncluttered.
SAMPLE_RATE = 4096                 # Hz -- samples per second
DELTA_T     = 1.0 / SAMPLE_RATE    # time step between samples (s)
DURATION    = 32                   # seconds of data in the analysis segment
F_LOW       = 20.0                 # analysis low-frequency cutoff (Hz)

# True parameters of the injected source (our "ground truth"). Recovery code
# downstream should reproduce these -- that's how you validate the pipeline.
MASS1, MASS2 = 65, 85             # solar masses (GW150914-like)
DISTANCE     = 1000                # Mpc -- larger distance -> weaker signal -> lower SNR
APPROXIMANT  = "IMRPhenomD"        # aligned-spin inspiral-merger-ringdown model; fast + standard
MERGER_OFFSET = DURATION / 2.0     # put the merger mid-segment so it survives
                                   # both the conditioning crop and the SNR crop
                                   # (whitening eats data off both ends)
NOISE_SEED   = 400                 # fixed seed -> reproducible noise realization

# Scales the noise amplitude. Signal amplitude is fixed by DISTANCE, so lowering
# this is effectively an SNR boost (SNR ~ signal / noise). Set to 1.0 for a true detectability test.
NOISE_SCALE  = .2

TLEN = DURATION * SAMPLE_RATE      # total number of time samples in the segment
FLEN = TLEN // 2 + 1               # number of positive-frequency bins (rFFT layout)
DELTA_F = 1.0 / DURATION           # frequency resolution = 1 / segment_duration


# --------------------------------------------------------------------------
# 1. Colored Gaussian noise from an analytic PSD
# --------------------------------------------------------------------------
# aLIGOZeroDetHighPower is the Advanced LIGO "design sensitivity" curve.
# from_string builds that PSD on our (FLEN, DELTA_F) grid; noise_from_psd then
# draws a Gaussian time series whose spectrum matches it -- "colored" noise
# (lots of low-frequency power), not flat white noise.
psd_for_noise = from_string("aLIGOZeroDetHighPower", FLEN, DELTA_F, F_LOW)
noise = noise_from_psd(TLEN, DELTA_T, psd_for_noise, seed=NOISE_SEED) * NOISE_SCALE
noise.start_time = 0.0             # anchor segment epoch at t = 0 for clean bookkeeping
print(f"Generated noise : {len(noise)} samples, {noise.duration:.4f} s")


# --------------------------------------------------------------------------
# 1b. Generate the CBC waveform  
# --------------------------------------------------------------------------
# get_td_waveform returns the plus/cross polarisations sampled at delta_t.
# By convention the merger sits at t = 0, so the epoch (start_time) is negative:
# the inspiral occupies the seconds before zero.
hp, hc = get_td_waveform(approximant=APPROXIMANT,
                         mass1=MASS1, mass2=MASS2,
                         distance=DISTANCE,
                         delta_t=DELTA_T, f_lower=F_LOW)
ts = hp                                   # use the plus polarisation as the signal
print(f"Waveform        : {len(ts)} samples, {ts.duration:.4f} s")


# ------------------------------------------------------------------
# (2) Frequency domain via PyCBC's FFT
# ------------------------------------------------------------------
# Forward FFT of the clean template -- a spectral sanity check before the
# signal gets buried in noise.
fseries = ts.to_frequencyseries()
freqs   = fseries.sample_frequencies      # frequency axis (Hz)
fft_amp = abs(fseries)                     # |FFT| = spectral amplitude per bin
print(f"FFT length      : {len(fseries)} bins")
print(f"Freq resolution : {fseries.delta_f:.3f} Hz")
# Loudest bin sits low: the inspiral dominates the energy (~f^-7/6), not the merger.
print(f"Peak frequency  : {freqs[fft_amp.numpy().argmax()]:.1f} Hz")

# ------------------------------------------------------------------
# (3) Inverse FFT via PyCBC — back to time domain
# ------------------------------------------------------------------
# Round-trip test on the untouched spectrum: FFT then IFFT should return the
# original to floating-point precision (~1e-13), confirming the transform pair
# is consistent. Trim to len(ts) because the rFFT layout can return one extra
# sample for odd-length inputs.
ts_ifft = fseries.to_timeseries()
residual = ts.numpy() - ts_ifft.numpy()[:len(ts)]
print(f"Max reconstruction error: {abs(residual).max():.3e}")

# ------------------------------------------------------------------
# (4) INJECT the signal into the colored Gaussian noise.
#     (Original code tried to read an undefined NOISE_FILE from disk;
#      we inject into the PSD noise generated in step 1 instead.)
# ------------------------------------------------------------------
merger_time = noise.duration / 2.0        # where we want the merger to land (mid-segment)

# The template has its merger at t=0 with a negative start_time. Shifting
# start_time by +merger_time slides the whole waveform so its merger lands at
# merger_time within the noise segment.
ts_shifted = ts.copy()
ts_shifted.start_time = float(ts.start_time) + merger_time   # ts.start_time < 0

# Add the shifted signal onto the noise sample-by-sample. The two arrays differ
# in length and start point, so compute the integer index where the signal
# begins in the noise array, then clip to the overlap (lo/hi) so we never write
# out of bounds.
data = noise.numpy().copy()
sig  = ts_shifted.numpy()
start_idx = int(round((float(ts_shifted.start_time) - float(noise.start_time)) * SAMPLE_RATE))
lo = max(start_idx, 0)                     # first valid destination index
hi = min(start_idx + len(sig), len(data))  # one past the last valid destination index
data[lo:hi] += sig[lo - start_idx: hi - start_idx]   # matching slice of the signal
signal_in_noise = TimeSeries(data, delta_t=DELTA_T, epoch=noise.start_time)
print(f"Injected merger at t = {merger_time:.3f} s")

# Whiten + band-pass to reveal the chirp buried in the noise.
#   whiten(4, 4)  : estimate the PSD from the data and divide it out, using 4 s
#                   segments with a 4 s max filter length. Flattens the noise
#                   floor so every frequency contributes equally; crops a few
#                   seconds off each end (why the merger sits mid-segment).
#   highpass(30)  : remove sub-30 Hz content remaining after whitening
#   lowpass_fir   : FIR low-pass at 300 Hz, order 8 -- keep the chirp's band and
#                   suppress high-frequency whitened noise.
# Order matters: whiten first (reshapes the whole spectrum), then trim the band.
white   = signal_in_noise.whiten(4, 4)
white   = highpass(white, 30.0)
white   = lowpass_fir(white, 300.0, 8)
t_white = white.sample_times.numpy()

# ------------------------------------------------------------------
# Plot A: the injection (noise, signal+noise, whitened zoom)
# ------------------------------------------------------------------
# Three stacked panels tell the detection story: raw noise (chirp invisible)
# -> signal+noise (still buried) -> whitened+bandpassed zoom (chirp emerges).
fig2, (bn, bs, bw) = plt.subplots(3, 1, figsize=(12, 12))

# Top: colored noise alone -- nothing visible, by design.
bn.plot(noise.sample_times, noise, color="gray", lw=0.6)
bn.set(title="Colored Gaussian LIGO noise (aLIGO design PSD)", xlabel="Time (s)", ylabel="Strain")
bn.grid(alpha=0.3)

# Middle: signal + noise. Red dashed line = true merger time; the chirp is
# present but hidden under the noise at raw scale.
bs.plot(signal_in_noise.sample_times, signal_in_noise, color="steelblue", lw=0.6)
bs.axvline(merger_time, color="red", ls="--", lw=1, label="Merger")
bs.set(title="Signal injected into noise", xlabel="Time (s)", ylabel="Strain")
bs.legend(); bs.grid(alpha=0.3)

# Bottom: zoom to a short window around the merger on the whitened data, where
# the rising-frequency chirp is finally visible.
mask = (t_white > merger_time - 0.5) & (t_white < merger_time + 0.1)
bw.plot(t_white[mask], white.numpy()[mask], color="crimson", lw=1.0)
bw.axvline(merger_time, color="red", ls="--", lw=1, label="Merger")
bw.set(title="Whitened + Band-passed (30-300 Hz) - the chirp emerges",
       xlabel="Time (s)", ylabel="Whitened strain (arb. units)")
bw.legend(); bw.grid(alpha=0.3)
plt.tight_layout()                     # applies to the current figure (fig2) only
plt.savefig("injection_plots.png", dpi=130, bbox_inches="tight")
print("Figures saved.")
