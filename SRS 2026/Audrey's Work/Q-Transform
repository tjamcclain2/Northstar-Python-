"""
The Q-Transform is a time frequency series analysis method that decomposes a signal onto a logarithmically spaced
frequency axis. The output shows how signal energy is disturbed across frequency over time and the method s used to
search for statistically significant excess power against a noise background.

The Q-transform is a constant-Q, wavelet-style transform: where the STFT involves the signal with a fixed-width window
at every frequency, the Q-transform uses a window whose width scales with frequency. That adaptivity is the reason I
used it for a compact-binary signal. A fixed STFT window forces a single compromise across the whole track: resolve
the early inspiral and you blur the merger, or resolve the merger and you over-chop the inspiral.

It is important to note that you have to whiten the data first because the Q-scan runs normally on whitened data so that
under Gaussian noise the normalized tile energies follow a normal distribution. Meaning that a tile is significant when
its energy sits far in the distributions tail.

The Q-transform works best on loud (SNR ≳ 8–10), stellar-mass compact-binary mergers whose frequency sweeps widely
through the sensitive band and fits comfortably inside the analysis segment — and it's least useful for faint signals,
very heavy merger-dominated systems, and anything narrowband. For example Q transform works best for GW150914, roughly
30 + 30 M☉ at a few hundred Mpc. Faint, far-away signals that matched filtering still recovers cleanly will be
invisible or ambiguous in a Q-scan.
"""
from pycbc.psd import from_string
from pycbc.noise import noise_from_psd
from pycbc.types import TimeSeries
from pycbc.filter import highpass, lowpass_fir
from pycbc.waveform import get_td_waveform
import matplotlib
matplotlib.use("Agg")              # headless backend: render straight to PNG, no GUI
import matplotlib.pyplot as plt
import matplotlib.colors as mcolors
import warnings
warnings.filterwarnings("ignore")  # suppress PyCBC/matplotlib deprecation chatter

# --------------------------------------------------------------------------
# 0. Configuration
# --------------------------------------------------------------------------
# All the knobs live here so the physics sections below stay clean. Sample
# rate, segment length, and cutoffs are chosen to mimic a realistic aLIGO
# analysis segment.
SAMPLE_RATE = 4096                 # Hz -- samples per second
DELTA_T     = 1.0 / SAMPLE_RATE    # time step between samples (s)
DURATION    = 32                   # seconds of data in the analysis segment
F_LOW       = 20.0                 # analysis low-frequency cutoff (Hz)

# True parameters of the injected source (our "ground truth"). Recovery code
# downstream should reproduce these; that's how you know the pipeline works.
MASS1, MASS2 = 85, 65             # component masses (solar masses)
DISTANCE     = 1000                # Mpc -- larger distance -> weaker signal -> lower SNR
APPROXIMANT  = "IMRPhenomD"        # aligned-spin inspiral-merger-ringdown model; fast + standard
MERGER_OFFSET = DURATION / 2.0     # put the merger mid-segment so it survives
                                   # both the conditioning crop and the SNR crop
                                   # (whitening eats data at both ends)
NOISE_SEED   = 400                 # fixed seed -> reproducible noise realization

# Scales the noise amplitude. Because the injected signal amplitude is fixed by
# DISTANCE, shrinking the noise is effectively a hidden SNR *boost* (SNR ~ signal
# / noise). At 0.2 the chirp is much easier to see than in real design-sensitivity
# noise (1.0). Handy for demos; set to 1.0 for realistic detectability tests.
NOISE_SCALE  = .2

TLEN = DURATION * SAMPLE_RATE      # total number of time samples in the segment
FLEN = TLEN // 2 + 1               # number of positive-frequency bins (rFFT layout)
DELTA_F = 1.0 / DURATION           # frequency resolution = 1 / segment_duration


# --------------------------------------------------------------------------
# 1. Colored Gaussian noise from an analytic PSD
# --------------------------------------------------------------------------
# aLIGOZeroDetHighPower is the Advanced LIGO "design sensitivity" curve.
# from_string builds that PSD on our (FLEN, DELTA_F) grid; noise_from_psd then
# draws a random Gaussian time series whose spectrum matches it -- i.e. "colored"
# noise (more power at low frequency), not flat white noise.
psd_for_noise = from_string("aLIGOZeroDetHighPower", FLEN, DELTA_F, F_LOW)
noise = noise_from_psd(TLEN, DELTA_T, psd_for_noise, seed=NOISE_SEED) * NOISE_SCALE
noise.start_time = 0.0             # anchor the segment epoch at t = 0 for clean bookkeeping
print(f"Generated noise : {len(noise)} samples, {noise.duration:.4f} s")


# --------------------------------------------------------------------------
# 1b. Generate the CBC waveform  (THIS WAS MISSING -> nothing was 'ts')
# --------------------------------------------------------------------------
# get_td_waveform returns the plus/cross polarisations sampled at delta_t.
# By convention the merger sits at t = 0, so the epoch (start_time) is negative:
# the inspiral occupies the seconds *before* zero.
hp, hc = get_td_waveform(approximant=APPROXIMANT,
                         mass1=MASS1, mass2=MASS2,
                         distance=DISTANCE,
                         delta_t=DELTA_T, f_lower=F_LOW)
ts = hp                                   # use the plus polarisation as the signal
print(f"Waveform        : {len(ts)} samples, {ts.duration:.4f} s")


# ------------------------------------------------------------------
# (2) Frequency domain via PyCBC's FFT
# ------------------------------------------------------------------
# Forward FFT of the clean template. Kept here mostly as a spectral sanity
# check on the waveform before it gets buried in noise.
fseries = ts.to_frequencyseries()
freqs   = fseries.sample_frequencies      # frequency axis (Hz)
fft_amp = abs(fseries)                     # |FFT| = spectral amplitude per bin
print(f"FFT length      : {len(fseries)} bins")
print(f"Freq resolution : {fseries.delta_f:.3f} Hz")
# Loudest bin sits low (inspiral dominates the energy, ~f^-7/6), not at merger.
print(f"Peak frequency  : {freqs[fft_amp.numpy().argmax()]:.1f} Hz")

# ------------------------------------------------------------------
# (3) Inverse FFT via PyCBC — back to time domain
# ------------------------------------------------------------------
# Round-trip test on the untouched spectrum: FFT then IFFT should return the
# original to floating-point precision (~1e-13). Confirms the transform pair is
# consistent before we start modifying spectra elsewhere. Trim to len(ts) because
# the rFFT layout can hand back one extra sample for odd-length inputs.
ts_ifft = fseries.to_timeseries()
residual = ts.numpy() - ts_ifft.numpy()[:len(ts)]
print(f"Max reconstruction error: {abs(residual).max():.3e}")

# ------------------------------------------------------------------
# (4) INJECT the signal into the colored Gaussian noise.
#     (Original code tried to read an undefined NOISE_FILE from disk;
#      we inject into the PSD noise generated in step 1 instead.)
# ------------------------------------------------------------------
merger_time = noise.duration / 2.0        # where we want the merger to land (mid-segment)

# The template has its merger at t=0 with a negative start_time. Shifting
# start_time by +merger_time slides the whole waveform so its merger lands at
# merger_time within the noise segment.
ts_shifted = ts.copy()
ts_shifted.start_time = float(ts.start_time) + merger_time   # ts.start_time < 0

# Add the shifted signal onto the noise sample-by-sample. Because the two arrays
# have different lengths and start points, we compute the integer index in the
# noise array where the signal begins, then clip to the overlap region so we
# never write out of bounds (lo/hi guard the edges).
data = noise.numpy().copy()
sig  = ts_shifted.numpy()
start_idx = int(round((float(ts_shifted.start_time) - float(noise.start_time)) * SAMPLE_RATE))
lo = max(start_idx, 0)                     # first valid destination index
hi = min(start_idx + len(sig), len(data))  # one past the last valid destination index
data[lo:hi] += sig[lo - start_idx: hi - start_idx]   # matching slice of the signal
signal_in_noise = TimeSeries(data, delta_t=DELTA_T, epoch=noise.start_time)
print(f"Injected merger at t = {merger_time:.3f} s")

# Whiten + band-pass to reveal the chirp buried in the noise.
#   whiten(4, 4)  : estimates the PSD from the data and divides it out, using
#                   4 s segments with a 4 s max filter duration. Flattens the
#                   noise floor so every frequency contributes equally; crops
#                   a few seconds off each end (why the merger sits mid-segment).
#   highpass(30)  : remove sub-30 Hz content left after whitening
#   lowpass_fir   : FIR low-pass at 300 Hz, order 8 -- keeps the band where the
#                   chirp lives and suppresses high-frequency whitened noise.
# Order matters: whiten first (it reshapes the whole spectrum), then trim the band.
white   = signal_in_noise.whiten(4, 4)
white   = highpass(white, 30.0)
white   = lowpass_fir(white, 300.0, 8)
t_white = white.sample_times.numpy()

# ------------------------------------------------------------------
# Plot B: the injection (noise, signal+noise, whitened zoom)
# ------------------------------------------------------------------
# Three stacked panels tell the story: raw noise (chirp invisible) -> signal+noise
# (still buried) -> whitened+bandpassed zoom (chirp finally visible near merger).
fig2, (bn, bs, bw) = plt.subplots(3, 1, figsize=(12, 12))

# Top: the colored noise on its own -- nothing to see, by design.
bn.plot(noise.sample_times, noise, color="gray", lw=0.6)
bn.set(title="Colored Gaussian LIGO noise (aLIGO design PSD)", xlabel="Time (s)", ylabel="Strain")
bn.grid(alpha=0.3)

# Middle: signal + noise. The red dashed line marks the true merger time; the
# chirp is present but hidden under the noise at raw scale.
bs.plot(signal_in_noise.sample_times, signal_in_noise, color="steelblue", lw=0.6)
bs.axvline(merger_time, color="red", ls="--", lw=1, label="Merger")
bs.set(title="Signal injected into noise", xlabel="Time (s)", ylabel="Strain")
bs.legend(); bs.grid(alpha=0.3)

# Bottom: zoom to a short window around the merger on the whitened data, where
# the rising-frequency chirp is now clearly visible.
mask = (t_white > merger_time - 0.5) & (t_white < merger_time + 0.1)
bw.plot(t_white[mask], white.numpy()[mask], color="crimson", lw=1.0)
bw.axvline(merger_time, color="red", ls="--", lw=1, label="Merger")
bw.set(title="Whitened + Band-passed (30-300 Hz) - the chirp emerges",
       xlabel="Time (s)", ylabel="Whitened strain (arb. units)")
bw.legend(); bw.grid(alpha=0.3)
plt.tight_layout()
plt.savefig("pycbc_injection_plots.png", dpi=130, bbox_inches="tight")
print("Figures saved.")

# ------------------------------------------------------------------
# (5) Q-TRANSFORM: time-frequency view of the injected chirp
# ------------------------------------------------------------------
# PyCBC's TimeSeries.qtransform does NOT whiten internally -- it just takes
# the FFT of whatever series you hand it and tiles it into (time, log-freq,
# Q) bins. Feeding it the *raw* signal_in_noise would just show the shape
# of the noise PSD (huge power at low frequency, nothing interesting at
# the merger). So we run it on `white`, the whitened + band-passed series
# already computed above -- exactly like real detector Q-scans, which are
# always made on whitened strain.

qtrans_half_window = 1.0                       # seconds shown either side of merger
q_start = merger_time - qtrans_half_window
q_end   = merger_time + qtrans_half_window
seg_for_q = white.time_slice(q_start, q_end)   # crop to a 2 s window around merger

# qtransform returns the tiling grid: time axis, frequency axis (log-spaced),
# and a 2-D power array shaped [n_freq, n_time].
times, qfreqs, power = seg_for_q.qtransform(
    delta_t=1.0 / 256,      # time resolution of the output grid (256 Hz)
    logfsteps=200,          # number of log-spaced frequency bins
    qrange=(4, 64),         # range of quality factors Q searched (picks best-fit tiling)
    frange=(20, 500),       # frequency range to display (Hz)
)

fig3, ax_q = plt.subplots(figsize=(10, 6))
# pcolormesh draws the time-frequency energy map. LogNorm on the color scale
# so the bright chirp track isn't washed out by the dimmer background tiles;
# vmin is floored at 1e-3 to avoid log(0).
mesh = ax_q.pcolormesh(
    times, qfreqs, power,
    shading="auto", cmap="viridis",
    norm=mcolors.LogNorm(vmin=max(power.min(), 1e-3), vmax=power.max())
)
ax_q.set_yscale("log")                         # log frequency axis matches the log-spaced bins
ax_q.axvline(merger_time, color="white", ls="--", lw=1.2, label="Injected merger")
ax_q.set(title="Q-transform of whitened data (chirp time-frequency track)",
         xlabel="Time (s)", ylabel="Frequency (Hz)")
ax_q.legend(loc="upper left")
cbar = fig3.colorbar(mesh, ax=ax_q)
cbar.set_label("Normalized tile energy")       # the sweeping bright arc = the chirp rising in frequency
plt.tight_layout()
plt.savefig("q-transform_plot.png", dpi=130, bbox_inches="tight")
print("Q-transform figure saved.")
