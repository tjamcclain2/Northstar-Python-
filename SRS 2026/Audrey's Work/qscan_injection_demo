"""
The loudness curve produced by this code represents how much gravitational-wave energy is passing through the detector
band at each moment — and because a compact binary's emission has a very particular time structure, the shape of that
curve maps directly onto the physics of the merger.

The rise represents: the inspiral. Two things happen simultaneously as the binary approaches merger: the frequency rises
into your sensitive band (the whitened, band-passed 30–300 Hz window), and the intrinsic amplitude grows because the
masses are moving faster and closer. The peak represents the merger. The loudest instant is the moment the two
horizons actually merge. the fall-off represents the ringdown. After merging, the remnant is a single perturbed black
hole that "rings" as it settles to a stationary Kerr state, radiating damped sinusoids (quasi-normal modes) at a
frequency and decay time set by the final mass and spin. The energy drops off fast, so the curve falls steeply after
the peak.

One thing to consider is this is loudness in the detector's whitened frame, not raw astrophysical energy flux. Whitening
reweights every frequency by the noise PSD, so the curve reflects how loud the event is relative to how well your detector
hears each frequency.
"""

from pycbc.psd import from_string
from pycbc.noise import noise_from_psd
from pycbc.types import TimeSeries
from pycbc.filter import highpass, lowpass_fir
from pycbc.waveform import get_td_waveform
import matplotlib
matplotlib.use("Agg")                  # headless backend: render to file, no display needed
import matplotlib.pyplot as plt
import matplotlib.colors as mcolors
import numpy as np
from scipy.signal import find_peaks
import warnings
warnings.filterwarnings("ignore")      # silence PyCBC/matplotlib deprecation chatter

# --------------------------------------------------------------------------
# 0. Configuration
# --------------------------------------------------------------------------
SAMPLE_RATE = 4096                 # Hz -- standard LIGO analysis rate; Nyquist = 2048 Hz
DELTA_T     = 1.0 / SAMPLE_RATE    # sample spacing in seconds
DURATION    = 32                   # seconds of data in the segment
F_LOW       = 20.0                 # analysis low-frequency cutoff (Hz); waveform + PSD start here

# True parameters of the injected source (our "ground truth").
MASS1, MASS2 = 85, 65              # solar masses; heavy stellar-mass BBH (chirp mass ~64.6 Msun)
DISTANCE     = 1000                # Mpc -- primary knob for the injected SNR (farther = quieter)
APPROXIMANT  = "IMRPhenomD"        # aligned-spin inspiral-merger-ringdown model; fast + standard
MERGER_OFFSET = DURATION / 2.0     # place the merger mid-segment so it survives both the
                                   # conditioning crop and the SNR crop (edges get eaten)
NOISE_SEED   = 400                 # fixed seed -> reproducible noise realisation

# Amplitude multiplier applied to the noise before injection. This is
# effectively a *hidden SNR knob*: scaling the noise by 0.2 raises the
# injected SNR ~5x at fixed DISTANCE. Set to 1.0 if you want DISTANCE alone
# to control SNR and to keep the noise at true aLIGO design amplitude.
NOISE_SCALE  = .2

TLEN = DURATION * SAMPLE_RATE      # total number of time samples in the segment
FLEN = TLEN // 2 + 1               # number of one-sided frequency bins (real FFT)
DELTA_F = 1.0 / DURATION           # frequency resolution = 1 / segment length


# --------------------------------------------------------------------------
# 1. Colored Gaussian noise from an analytic PSD
# --------------------------------------------------------------------------
# aLIGOZeroDetHighPower is the Advanced LIGO "design sensitivity" curve.
# from_string samples that analytic PSD onto our (FLEN, DELTA_F) grid;
# noise_from_psd then draws a Gaussian time series whose spectrum matches it.
psd_for_noise = from_string("aLIGOZeroDetHighPower", FLEN, DELTA_F, F_LOW)
noise = noise_from_psd(TLEN, DELTA_T, psd_for_noise, seed=NOISE_SEED) * NOISE_SCALE
noise.start_time = 0.0             # anchor the segment epoch at t = 0 for clean bookkeeping
print(f"Generated noise : {len(noise)} samples, {noise.duration:.4f} s")


# --------------------------------------------------------------------------
# 1b. Generate the CBC waveform
# --------------------------------------------------------------------------
# get_td_waveform returns the plus/cross polarisations sampled at delta_t.
# By convention the merger sits at t = 0, so the epoch (start_time) is
# negative -- the inspiral occupies the seconds *before* zero.
hp, hc = get_td_waveform(approximant=APPROXIMANT,
                         mass1=MASS1, mass2=MASS2,
                         distance=DISTANCE,
                         delta_t=DELTA_T, f_lower=F_LOW)
ts = hp                            # use the plus polarisation as the signal to inject
print(f"Waveform        : {len(ts)} samples, {ts.duration:.4f} s")


# ------------------------------------------------------------------
# (2) Frequency domain via PyCBC's FFT
# ------------------------------------------------------------------
# to_frequencyseries does the forward real FFT. Note the reported peak
# frequency sits near F_LOW, NOT at the merger frequency: the inspiral
# amplitude spectrum falls off as ~f^(-7/6), so most spectral weight
# piles up at low frequency even though the merger reaches ~100+ Hz.
# (The Q-transform in step 5 is what surfaces that high-frequency track.)
fseries = ts.to_frequencyseries()
freqs   = fseries.sample_frequencies
fft_amp = abs(fseries)
print(f"FFT length      : {len(fseries)} bins")
print(f"Freq resolution : {fseries.delta_f:.3f} Hz")
print(f"Peak frequency  : {freqs[fft_amp.numpy().argmax()]:.1f} Hz")

# ------------------------------------------------------------------
# (3) Inverse FFT via PyCBC -- back to time domain
# ------------------------------------------------------------------
# Round-trip sanity check: FFT then IFFT should return the original series
# to floating-point precision. A tiny residual (~1e-13) confirms the
# transform pair is lossless and our normalisation conventions line up.
ts_ifft = fseries.to_timeseries()
residual = ts.numpy() - ts_ifft.numpy()[:len(ts)]
print(f"Max reconstruction error: {abs(residual).max():.3e}")

# ------------------------------------------------------------------
# (4) INJECT the signal into the colored Gaussian noise.
# ------------------------------------------------------------------
merger_time = noise.duration / 2.0        # where we want the merger to land in the segment

# Shift the waveform so its t=0 (merger) sits at merger_time in the segment.
# ts.start_time is negative, so adding merger_time slides the whole inspiral
# forward to end at merger_time.
ts_shifted = ts.copy()
ts_shifted.start_time = float(ts.start_time) + merger_time

# Add the shifted waveform into the noise sample-by-sample. Convert the
# waveform's start time to a sample index in the noise array, then clip the
# overlap to [0, len(data)] so a waveform that would spill past either edge
# of the segment is truncated instead of indexing out of bounds.
data = noise.numpy().copy()
sig  = ts_shifted.numpy()
start_idx = int(round((float(ts_shifted.start_time) - float(noise.start_time)) * SAMPLE_RATE))
lo = max(start_idx, 0)                                   # first valid noise index
hi = min(start_idx + len(sig), len(data))                # one past last valid noise index
data[lo:hi] += sig[lo - start_idx: hi - start_idx]       # matching slice of the waveform
signal_in_noise = TimeSeries(data, delta_t=DELTA_T, epoch=noise.start_time)
print(f"Injected merger at t = {merger_time:.3f} s")

# Whiten (flatten the noise spectrum) then band-pass to isolate the band
# where the chirp lives. whiten(4, 4): 4 s PSD-estimation segments, 4 s max
# filter length. After whitening the chirp stands out against flat noise.
white   = signal_in_noise.whiten(4, 4)
white   = highpass(white, 30.0)           # drop residual low-freq content below the band
white   = lowpass_fir(white, 300.0, 8)    # FIR low-pass at 300 Hz, order 8, to cap the band
t_white = white.sample_times.numpy()

# ------------------------------------------------------------------
# (5) Q-TRANSFORM: time-frequency view of the injected chirp
# ------------------------------------------------------------------
# PyCBC's TimeSeries.qtransform does NOT whiten internally -- it just takes
# the FFT of whatever series you hand it and tiles it into (time, log-freq,
# Q) bins. Feeding it the *raw* signal_in_noise would just show the shape
# of the noise PSD (huge power at low frequency, nothing interesting at
# the merger). So we run it on `white`, the whitened + band-passed series
# already computed above -- exactly like real detchar Q-scans, which are
# always made on whitened strain.

qtrans_half_window = 1.0                       # seconds shown either side of the merger
q_start = merger_time - qtrans_half_window
q_end   = merger_time + qtrans_half_window
seg_for_q = white.time_slice(q_start, q_end)   # crop to a 2 s window around the merger

# Returns: times (1-D, Nt), qfreqs (1-D, Nf), power (2-D, [Nf, Nt]).
times, qfreqs, power = seg_for_q.qtransform(
    delta_t=1.0 / 256,      # output time resolution (256 Hz grid) -- enough for the chirp
    logfsteps=200,          # number of log-spaced frequency bins
    qrange=(4, 64),         # range of quality factors searched (auto-picks best tiling)
    frange=(20, 500),       # frequency range to display (Hz)
)

fig3, ax_q = plt.subplots(figsize=(10, 6))
# LogNorm so the faint inspiral track isn't washed out by the bright merger;
# clamp vmin above zero since LogNorm can't handle non-positive values.
mesh = ax_q.pcolormesh(
    times, qfreqs, power,
    shading="auto", cmap="viridis",
    norm=mcolors.LogNorm(vmin=max(power.min(), 1e-3), vmax=power.max())
)
ax_q.set_yscale("log")                                   # log-freq matches the Q-tiling
ax_q.axvline(merger_time, color="white", ls="--", lw=1.2, label="Injected merger")
ax_q.set(title="Q-transform of whitened data (chirp time-frequency track)",
         xlabel="Time (s)", ylabel="Frequency (Hz)")
ax_q.legend(loc="upper left")
cbar = fig3.colorbar(mesh, ax=ax_q)
cbar.set_label("Normalized tile energy")
plt.tight_layout()
plt.savefig("qtransform_plot.png", dpi=130, bbox_inches="tight")
print("Q-transform figure saved.")

# ------------------------------------------------------------------
# (6) LOUDNESS CURVE + PEAK / CHANGEPOINT DETECTION
# ------------------------------------------------------------------
# Collapse the 2D Q-plane down to a 1D "excess power vs time" curve by
# summing energy across all frequency bins at each time step. This is
# essentially what burst/glitch trigger pipelines (e.g. Omicron) threshold
# on to decide "something happened here."
# power is [Nf, Nt], so axis=0 (frequency) leaves one value per time bin.
loudness = power.sum(axis=0)          # one value per time bin in `times`

# --- Peak detection --------------------------------------------------
# Find the loudest instant(s). `find_peaks` handles the case where there
# are multiple candidate bursts in the window; we expect one dominant
# merger peak here. The prominence floor (10% of the max) rejects ripples.
peak_idx, _ = find_peaks(loudness, prominence=loudness.max() * 0.1)
if len(peak_idx) == 0:                       # fallback if no peak clears the prominence floor
    peak_idx = np.array([np.argmax(loudness)])
loudest_idx  = peak_idx[np.argmax(loudness[peak_idx])]   # the single strongest peak
loudest_time = times[loudest_idx]
print(f"Loudest tile at t = {loudest_time:.4f} s "
      f"(injected merger was at {merger_time:.4f} s)")

# --- Changepoint / onset detection ------------------------------------
# Estimate the "quiet" noise-floor level from the edges of the window
# (away from the merger) using a robust median/MAD statistic, then walk
# backward from the peak to find the first time the loudness rises above
# baseline + N*MAD -- i.e. where the transient "turns on." Median/MAD is
# used instead of mean/std so the merger itself doesn't skew the baseline.
edge_frac = 0.25                       # fraction of samples at each end used for the baseline
n_edge = max(int(len(loudness) * edge_frac), 5)          # at least 5 samples per edge
baseline_samples = np.concatenate([loudness[:n_edge], loudness[-n_edge:]])
baseline_median  = np.median(baseline_samples)
baseline_mad     = np.median(np.abs(baseline_samples - baseline_median)) * 1.4826  # -> ~sigma
threshold = baseline_median + 5 * baseline_mad           # 5-MAD excess-power threshold

# Walk backward from the peak; the onset is the first sample (going forward
# in time) where loudness first crossed the threshold before the peak.
above = loudness > threshold
onset_idx = 0
for i in range(loudest_idx, -1, -1):
    if not above[i]:                   # first sub-threshold sample below the peak...
        onset_idx = i + 1              # ...so the onset is the sample just after it
        break
onset_time = times[onset_idx]
print(f"Changepoint (onset) detected at t = {onset_time:.4f} s, "
      f"threshold = {threshold:.3e}")

# --- Plot: loudness curve with peak + onset marked --------------------
# Log-y so the pre-merger rise is visible alongside the peak. Vertical
# markers compare the detected peak/onset against the known injected merger.
fig4, ax_l = plt.subplots(figsize=(10, 5))
ax_l.plot(times, loudness, color="darkslateblue", lw=1.2,
          label="Loudness (Σ power over freq)")
ax_l.axhline(threshold, color="gray", ls=":", lw=1,
             label="Onset threshold (baseline + 5·MAD)")
ax_l.axvline(merger_time, color="red", ls="--", lw=1.2, label="Injected merger")
ax_l.axvline(loudest_time, color="gold", ls="-", lw=1.5,
             label=f"Detected peak (t={loudest_time:.3f}s)")
ax_l.axvline(onset_time, color="seagreen", ls="-.", lw=1.5,
             label=f"Detected onset (t={onset_time:.3f}s)")
ax_l.set(title="Loudness curve (Q-transform energy summed over frequency)",
         xlabel="Time (s)", ylabel="Summed tile energy")
ax_l.set_yscale("log")
ax_l.legend(loc="upper left", fontsize=9)
ax_l.grid(alpha=0.3)
plt.tight_layout()
plt.savefig("loudness_curve_plot.png", dpi=130, bbox_inches="tight")
print("Loudness curve figure saved.")
